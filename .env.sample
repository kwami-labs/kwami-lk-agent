# =============================================================================
# Kwami AI Agents - Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in your credentials:
#   cp .env.sample .env
#
# =============================================================================

# =============================================================================
# LiveKit Configuration
# =============================================================================
# Get these from https://cloud.livekit.io/projects/YOUR_PROJECT/settings/keys

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-api-key
LIVEKIT_API_SECRET=your-api-secret

# =============================================================================
# AI Provider API Keys
# =============================================================================

# OpenAI - For LLM (GPT-4) and optionally TTS
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key

# Deepgram - For Speech-to-Text (STT)
# Get from: https://console.deepgram.com/
DEEPGRAM_API_KEY=your-deepgram-key

# Cartesia - For Text-to-Speech (TTS)
# Get from: https://play.cartesia.ai/
CARTESIA_API_KEY=your-cartesia-key

# ElevenLabs - Alternative TTS
# Get from: https://elevenlabs.io/
ELEVEN_API_KEY=your-elevenlabs-key

# Google - For Gemini models
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-key

# AssemblyAI - Alternative STT
# Get from: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your-assemblyai-key

# Anthropic - Alternative LLM (Claude)
# Get from: https://platform.claude.com/
ANTHROPIC_API_KEY=your-anthropic-key

# Groq - Fast inference (Llama, Mixtral)
# Get from: https://console.groq.com/
GROQ_API_KEY=your-groq-key

# DeepSeek - DeepSeek Chat & Reasoner
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your-deepseek-key

# =============================================================================
# Web Search
# =============================================================================
# Get your API key at https://tavily.com/
# The agent runs search on the server and sends results to the client for display.

TAVILY_API_KEY=tvly-your-tavily-api-key

# SerpApi key for real product search (Google Shopping).
# When set, the agent uses product_search so users see actual product cards (image, name, price) instead of store links.
# Get key at https://serpapi.com/

SERPAPI_KEY=your-serpapi-key

# =============================================================================
# Long-term Memory - Zep Cloud
# =============================================================================
# Each Kwami maintains independent persistent memory of all conversations.
# 
# Get your API key:
#   1. Create account at https://app.getzep.com/
#   2. Go to Project Settings > API Keys
#   3. Create a new API key
#
# More info: https://www.getzep.com/

ZEP_API_KEY=z_your-zep-api-key

# =============================================================================
# Navigation - Browser Browsing (Optional)
# =============================================================================
# The agent can browse the web in a headless Chromium browser and stream
# the viewport to the user as a LiveKit video track.
# These settings are optional; defaults work out of the box.

NAVIGATION_FPS=10
NAVIGATION_VIEWPORT_WIDTH=1280
NAVIGATION_VIEWPORT_HEIGHT=720

# =============================================================================
# Credits System - Usage Reporting
# =============================================================================
# The agent reports AI usage to the API so credits can be deducted.
# These must match the values in the kwami-ai-api .env.

KWAMI_API_URL=http://localhost:8080
KWAMI_API_KEY=your-random-kwami-api-key
